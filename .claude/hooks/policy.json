{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [],
    "enableWeakerNestedSandbox": false,
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "pypi.org",
        "*.pythonhosted.org",
        "crates.io",
        "github.com",
        "*.githubusercontent.com"
      ],
      "allowUnixSockets": [],
      "allowAllUnixSockets": false,
      "allowLocalBinding": false
    },
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gh",
        "~/.netrc",
        "~/.gnupg",
        "~/.docker"
      ],
      "allowWrite": []
    }
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*credentials*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(sudo:*)",
      "WebFetch(domain:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(terraform:*)",
      "Bash(kubectl:*)",
      "Bash(npm publish:*)"
    ],
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.claude.com)"
    ]
  },
  "budget": {
    "max_tool_calls_per_session": 400,
    "state_dir": ".agent"
  },
  "bash": {
    "enabled": true,
    "deny": [
      "\\brm\\s+-\\S*[rf]\\S*\\s+\\*",
      "\\brm\\b[^;&|]*\\s(/|~|\\$HOME)/?(\\s|$)",
      "git\\s+push\\b.*--force(-with-lease)?\\b.*\\b(main|master)\\b",
      "--no-verify",
      "\\bchmod\\s+777\\b",
      "\\b(DROP|TRUNCATE)\\s+(TABLE|DATABASE)\\b",
      "\\bmkfs\\b|\\bdd\\s+if=.*of=/dev/",
      "curl\\b[^|]*\\|\\s*(ba)?sh",
      ">\\s*\\.env"
    ]
  }
}
