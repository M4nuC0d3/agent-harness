{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "python3 .claude/hooks/preflight.py" }
    ],
    "beforeShellExecution": [
      { "command": "python3 .claude/hooks/guard.py", "failClosed": true }
    ],
    "afterShellExecution": [
      { "command": "python3 .claude/hooks/trace.py" }
    ],
    "afterFileEdit": [
      { "command": "python3 .claude/hooks/format.py" }
    ]
  }
}
