# Copy to .env and fill in only the providers you actually use.
# Loaded automatically if python-dotenv is installed.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# OpenAI-compatible local server (Ollama / vLLM / LM Studio)
LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
LOCAL_OPENAI_API_KEY=not-needed

# Optional global override: force EVERY agent onto one model.
#   AI_FORCE_MODEL=mock:mock                         # dry run, no network
#   AI_FORCE_MODEL=anthropic:claude-haiku-4-5-20251001
# AI_FORCE_MODEL=

# --- Subscription path (providers: claude_cli / codex_cli / gemini_cli) -----
# No API key needed; the CLI must be installed and logged in to your account.
# Override the binary or its args if a vendor changes flags:
# AI_CLAUDE_BIN=claude
# AI_CLAUDE_ARGS=-p {prompt}          # drop {prompt} to send it via stdin
# AI_CODEX_BIN=codex
# AI_CODEX_ARGS=exec {prompt}
# AI_GEMINI_BIN=gemini
# AI_GEMINI_ARGS=-p {prompt}
# AI_CLI_TIMEOUT=300                  # seconds per model call
#
# NOTE: gemini_cli uses your Google account only if GEMINI_API_KEY is UNSET.
# If it is set, the CLI authenticates with the key and bills API usage instead.
