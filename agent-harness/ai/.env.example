# Copy to .env and fill in only the providers you actually use.
# Loaded automatically if python-dotenv is installed.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# OpenAI-compatible local server (Ollama / vLLM / LM Studio)
LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
LOCAL_OPENAI_API_KEY=not-needed

# Optional global override: force EVERY agent onto one model.
#   AI_FORCE_MODEL=mock:mock                         # dry run, no network
#   AI_FORCE_MODEL=anthropic:claude-haiku-4-5-20251001
# AI_FORCE_MODEL=
